#!/bin/sh
basedir=$(dirname "$(echo "$0" | sed -e 's,\\,/,g')")

case `uname` in
    *CYGWIN*|*MINGW*|*MSYS*)
        if command -v cygpath > /dev/null 2>&1; then
            basedir=`cygpath -w "$basedir"`
        fi
    ;;
esac

if [ -z "$NODE_PATH" ]; then
  export NODE_PATH="/Users/hugopinto/Documents/ai-projects/apm-package-test/node_modules/.pnpm/tty-table@4.2.3/node_modules/tty-table/node_modules:/Users/hugopinto/Documents/ai-projects/apm-package-test/node_modules/.pnpm/tty-table@4.2.3/node_modules:/Users/hugopinto/Documents/ai-projects/apm-package-test/node_modules/.pnpm/node_modules"
else
  export NODE_PATH="/Users/hugopinto/Documents/ai-projects/apm-package-test/node_modules/.pnpm/tty-table@4.2.3/node_modules/tty-table/node_modules:/Users/hugopinto/Documents/ai-projects/apm-package-test/node_modules/.pnpm/tty-table@4.2.3/node_modules:/Users/hugopinto/Documents/ai-projects/apm-package-test/node_modules/.pnpm/node_modules:$NODE_PATH"
fi
if [ -x "$basedir/node" ]; then
  exec "$basedir/node"  "$basedir/../../../../../../tty-table@4.2.3/node_modules/tty-table/adapters/terminal-adapter.js" "$@"
else
  exec node  "$basedir/../../../../../../tty-table@4.2.3/node_modules/tty-table/adapters/terminal-adapter.js" "$@"
fi
