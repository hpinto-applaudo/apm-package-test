{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Read|Grep|Glob|Bash|Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node ${PLUGIN_ROOT}/scripts/block-env-access.js",
            "timeout": 5
          }
        ]
      }
    ]
  }
}